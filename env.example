# ── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=horand

# ── FastAPI ───────────────────────────────────────────
SECRET_KEY=your_very_long_random_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ──────────────────────────────────────────────
# Локально:
FRONTEND_URL=http://localhost:3000
# На сервері (замінити на свій домен):
# FRONTEND_URL=https://yourdomain.com

# ── Uploads ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── DigitalOcean Spaces (опційно) ─────────────────────
# Якщо USE_S3=true — фото зберігаються в DO Spaces
USE_S3=false
# S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
# S3_ACCESS_KEY=your_spaces_access_key
# S3_SECRET_KEY=your_spaces_secret_key
# S3_BUCKET_NAME=your_bucket_name
# S3_REGION=nyc3

# ── React (frontend) ──────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
# На сервері:
# REACT_APP_API_URL=https://yourdomain.com
